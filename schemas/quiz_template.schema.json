{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-mnemosyne.local/schemas/quiz_template.schema.json",
  "title": "QuizTemplate",
  "type": "object",
  "required": [
    "template_id",
    "learning_object_id",
    "activity_type",
    "prompt",
    "answer_ref"
  ],
  "properties": {
    "template_id": {
      "type": "string"
    },
    "learning_object_id": {
      "type": "string"
    },
    "activity_type": {
      "type": "string",
      "enum": [
        "recognition",
        "retrieval",
        "application",
        "conversation",
        "contrast"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "choices": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "answer_ref": {
      "type": "string"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "verified",
        "released"
      ]
    }
  }
}